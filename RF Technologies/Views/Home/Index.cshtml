@{
    ViewData["Title"] = "RF Technologies - Home";
    var messageSent = TempData["MessageSent"] != null && (bool)TempData["MessageSent"];
}

@model Contact

<section id="hero" class="hero section">
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-6 order-2 order-lg-1 d-flex flex-column justify-content-center">
                <h1 data-aos="fade-up">Scalable Software Solutions for Growing Businesses</h1>
                <p data-aos="fade-up" data-aos-delay="100">We are a team of dedicated developers engineering high-performance web and desktop applications using robust, enterprise-grade technology.</p>
                <div class="d-flex flex-column flex-md-row" data-aos="fade-up" data-aos-delay="200">
                    <a href="#contact" class="btn-get-started">Get a Quote <i class="bi bi-arrow-right"></i></a>
                    <a href="https://youtu.be/2Y1z9ideC4Q" class="glightbox btn-watch-video d-flex align-items-center justify-content-center ms-0 ms-md-4 mt-4 mt-md-0">
                        <i class="bi bi-play-circle"></i><span>Watch Video</span>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 order-1 order-lg-2 hero-img" data-aos="zoom-out">
                <img src="assets/img/hero-img.png" class="img-fluid animated" alt="RF Technologies Hero">
            </div>
        </div>
    </div>
</section>
<section id="about" class="about section">
    <div class="container" data-aos="fade-up">
        <div class="row gx-0">
            <div class="col-lg-6 d-flex flex-column justify-content-center" data-aos="fade-up" data-aos-delay="200">
                <div class="content">
                    <h3>Who We Are</h3>
                    <h2>RF Technologies: Engineering Excellence at Affordable Rates</h2>
                    <p>
                        At RF Technologies, we specialize in delivering secure, data-driven applications tailored to your operational needs. From complex cloud architectures to streamlined billing systems, our team leverages the latest frameworks to build solutions that guarantee performance, security, and scalability for your business.
                    </p>
                    <div class="text-center text-lg-start">
                        <a href="#services" class="btn-read-more d-inline-flex align-items-center justify-content-center align-self-center">
                            <span>Explore Our Services</span>
                            <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-flex align-items-center" data-aos="zoom-out" data-aos-delay="200">
                <img src="assets/img/about.jpg" class="img-fluid" alt="About RF Technologies">
            </div>
        </div>
    </div>
</section>
<section id="values" class="values section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Our Values</h2>
        <p>What drives our development</p>
    </div>
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <img src="assets/img/values-1.png" class="img-fluid" alt="Robust Architecture">
                    <h3>Robust Architecture</h3>
                    <p>We build on highly scalable frameworks, ensuring your software can handle growing data and user traffic without compromising speed.</p>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card">
                    <img src="assets/img/values-2.png" class="img-fluid" alt="Dedicated Support">
                    <h3>Dedicated Support</h3>
                    <p>Software requires maintenance. We provide continuous technical support, debugging, and system updates to keep your business running smoothly.</p>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card">
                    <img src="assets/img/values-3.png" class="img-fluid" alt="Agile Delivery">
                    <h3>Agile Delivery</h3>
                    <p>Time is money. We utilize modern CI/CD pipelines and agile methodologies to push updates faster and meet your strict project deadlines.</p>
                </div>
            </div>
        </div>
    </div>
</section>
<section id="services" class="services section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Services</h2>
        <p>Technical Capabilities</p>
    </div>
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="service-item item-cyan position-relative">
                    <i class="bi bi-code-square icon"></i>
                    <h3>Custom .NET Development</h3>
                    <p>Secure, high-performance web and desktop applications built with the latest .NET Core technologies, Entity Framework, and MVC architecture.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="service-item item-orange position-relative">
                    <i class="bi bi-hdd-network icon"></i>
                    <h3>Cloud & Database Solutions</h3>
                    <p>Scalable cloud hosting and sophisticated database design using SQL Server, MySQL, and Azure to keep your data structured and accessible.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="service-item item-teal position-relative">
                    <i class="bi bi-cart4 icon"></i>
                    <h3>E-Commerce & POS Systems</h3>
                    <p>End-to-end retail solutions including inventory tracking, secure user identity management, and real-time billing software.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="service-item item-red position-relative">
                    <i class="bi bi-phone icon"></i>
                    <h3>API Development</h3>
                    <p>RESTful APIs tailored for seamless third-party integrations, mobile application backends, and microservices architecture.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
                <div class="service-item item-indigo position-relative">
                    <i class="bi bi-clipboard-data icon"></i>
                    <h3>Enterprise Logistics & ERP</h3>
                    <p>Custom management systems tailored to complex workflows, such as tender tracking, catering logistics, and resource planning.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="600">
                <div class="service-item item-pink position-relative">
                    <i class="bi bi-tools icon"></i>
                    <h3>Legacy App Modernization</h3>
                    <p>Upgrade outdated software to modern tech stacks, improving security, fixing bugs, and enhancing the overall user interface.</p>
                </div>
            </div>
        </div>
    </div>
</section>
<section id="portfolio" class="portfolio section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Portfolio</h2>
        <p>Check our latest work</p>
    </div>
    <div class="container">
        <div class="isotope-layout" data-default-filter="*" data-layout="masonry" data-sort="original-order">
            <ul class="portfolio-filters isotope-filters" data-aos="fade-up" data-aos-delay="100">
                <li data-filter="*" class="filter-active">All</li>
                <li data-filter=".filter-app">Retail & POS</li>
                <li data-filter=".filter-product">Logistics</li>
                <li data-filter=".filter-branding">Web Apps</li>
            </ul>

            <div class="row gy-4 isotope-container" data-aos="fade-up" data-aos-delay="200">
                <div class="col-lg-4 col-md-6 portfolio-item isotope-item filter-app">
                    <div class="portfolio-content h-100">
                        <img src="assets/img/portfolio/app-1.jpg" class="img-fluid" alt="Mobile Retail POS">
                        <div class="portfolio-info">
                            <h4>Mobile Retail Billing System</h4>
                            <p>Complete POS and inventory application with built-in Identity management.</p>
                            <a href="assets/img/portfolio/app-1.jpg" title="Mobile Retail POS" data-gallery="portfolio-gallery-app" class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a>
                            <a href="portfolio-details.html" title="More Details" class="details-link"><i class="bi bi-link-45deg"></i></a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 portfolio-item isotope-item filter-product">
                    <div class="portfolio-content h-100">
                        <img src="assets/img/portfolio/product-1.jpg" class="img-fluid" alt="Catering Management">
                        <div class="portfolio-info">
                            <h4>Catering & Tender Logistics</h4>
                            <p>A centralized database application for tracking large-scale transport catering tenders.</p>
                            <a href="assets/img/portfolio/product-1.jpg" title="Catering Logistics" data-gallery="portfolio-gallery-product" class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a>
                            <a href="portfolio-details.html" title="More Details" class="details-link"><i class="bi bi-link-45deg"></i></a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 portfolio-item isotope-item filter-branding">
                    <div class="portfolio-content h-100">
                        <img src="assets/img/portfolio/branding-1.jpg" class="img-fluid" alt="Business Dashboard">
                        <div class="portfolio-info">
                            <h4>Corporate Finance Tracker</h4>
                            <p>An interactive web dashboard for real-time subsidiary and expense tracking.</p>
                            <a href="assets/img/portfolio/branding-1.jpg" title="Finance Tracker" data-gallery="portfolio-gallery-branding" class="glightbox preview-link"><i class="bi bi-zoom-in"></i></a>
                            <a href="portfolio-details.html" title="More Details" class="details-link"><i class="bi bi-link-45deg"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section id="tech-stack" class="tech-stack section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Tech Stack</h2>
        <p>Technologies We Master</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="swiper init-swiper">
            <script type="application/json" class="swiper-config">
                {
                  "loop": true,
                  "speed": 600,
                  "autoplay": {
                    "delay": 5000
                  },
                  "slidesPerView": "auto",
                  "pagination": {
                    "el": ".swiper-pagination",
                    "type": "bullets",
                    "clickable": true
                  },
                  "breakpoints": {
                    "320": {
                      "slidesPerView": 2,
                      "spaceBetween": 40
                    },
                    "480": {
                      "slidesPerView": 3,
                      "spaceBetween": 60
                    },
                    "640": {
                      "slidesPerView": 4,
                      "spaceBetween": 80
                    },
                    "992": {
                      "slidesPerView": 6,
                      "spaceBetween": 120
                    }
                  }
                }
            </script>
            <div class="swiper-wrapper align-items-center">
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/csharp/csharp-original.svg" class="img-fluid" alt="C#" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/dotnetcore/dotnetcore-original.svg" class="img-fluid" alt=".NET Core" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/microsoftsqlserver/microsoftsqlserver-original.svg" class="img-fluid" alt="MSSQL Server" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg" class="img-fluid" alt="PostgreSQL" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg" class="img-fluid" alt="MySQL" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/azure/azure-original.svg" class="img-fluid" alt="Azure" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg" class="img-fluid" alt="Java" style="height: 80px;">
                </div>
                <div class="swiper-slide">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bootstrap/bootstrap-original.svg" class="img-fluid" alt="Bootstrap" style="height: 80px;">
                </div>
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</section>
<section id="contact" class="contact section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Contact</h2>
        <p>Get In Touch With Our Team</p>
    </div>
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4">
            <div class="col-lg-6">
                <div class="row gy-4">
                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="200">
                            <i class="bi bi-geo-alt"></i>
                            <h3>Headquarters</h3>
                            <p>Bari Khagual, Danapur</p>
                            <p>Patna, Bihar 801105</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="300">
                            <i class="bi bi-telephone"></i>
                            <h3>Call Us</h3>
                            <p>+91-9905942199</p>
                            <p>+91-9304961453</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="400">
                            <i class="bi bi-envelope"></i>
                            <h3>Email Us</h3>
                            <p>rftechnologiesltd@gmail.com</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="500">
                            <i class="bi bi-clock"></i>
                            <h3>Open Hours</h3>
                            <p>Monday - Friday</p>
                            <p>9:00 AM - 06:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <form class="contact-form" asp-action="Index" method="post" style="display: block;">
                </form>
            </div>

            @if (messageSent)
            {
                <script>
                    Swal.fire({
                        title: 'Success!',
                        text: 'Your message has been sent successfully. Our team will get back to you shortly.',
                        icon: 'success',
                        confirmButtonText: 'Great'
                    });
                </script>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}