<style>
    /* Custom Styling for the Internship Page */
    .internship-hero {
        background: linear-gradient(to right, #f8f9fa, #ffffff);
        border-radius: 20px;
    }

    .track-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 15px;
        background: #fff;
    }

        .track-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            border-color: #0d6efd;
        }

    .icon-box {
        width: 60px;
        height: 60px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-size: 1.8rem;
        margin-bottom: 1rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 2rem 1rem;
        transition: transform 0.3s ease;
        border-bottom: 4px solid transparent;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .tech-badge {
        font-size: 0.75rem;
        font-weight: 600;
        background-color: #f1f3f5;
        color: #495057;
        padding: 0.4em 0.8em;
        border-radius: 50rem;
        margin-right: 0.3rem;
        margin-bottom: 0.5rem;
        display: inline-block;
    }
</style>

<section id="internship-program" class="section pt-5 mt-5">
    <div class="container" data-aos="fade-up">
        <div class="row gx-5 align-items-center internship-hero p-4 p-md-5 shadow-sm">

            <div class="col-lg-6 d-flex flex-column justify-content-center" data-aos="fade-up" data-aos-delay="200">
                <span class="text-primary fw-bold text-uppercase tracking-wide mb-2">RF Technologies Internship</span>
                <h1 class="display-5 fw-bold mb-4">Step Out of the Classroom. <br /><span class="text-primary">Build Real Software.</span></h1>
                <p class="lead text-muted mb-4">
                    Stop writing theoretical code. Join our 1-month intensive internship program to work on production-level projects, build a strong technical portfolio, and kickstart your career in tech under the guidance of industry experts.
                </p>
                <div class="d-flex gap-3">
                    <a href="#internship-domains" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
                        View Open Tracks <i class="bi bi-arrow-down ms-2"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-6 mt-5 mt-lg-0 text-center" data-aos="zoom-out" data-aos-delay="200">
                <img src="~/assets/img/about.jpg" class="img-fluid rounded-4 shadow" alt="Students coding at RF Technologies">
            </div>

        </div>
    </div>
</section>

<section id="stats" class="stats section bg-light py-5 my-5">
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4 text-center">

            <div class="col-lg-3 col-md-6">
                <div class="stat-card shadow-sm" style="border-bottom-color: #0d6efd;">
                    <i class="bi bi-mortarboard fs-1 text-primary mb-3 d-block"></i>
                    <h2 data-purecounter-start="0" data-purecounter-end="150" data-purecounter-duration="1" class="purecounter fw-bold mb-1">0</h2>
                    <p class="text-muted fw-semibold mb-0">Registered Students</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card shadow-sm" style="border-bottom-color: #ee6c20;">
                    <i class="bi bi-briefcase fs-1 mb-3 d-block" style="color: #ee6c20;"></i>
                    <h2 data-purecounter-start="0" data-purecounter-end="100" data-purecounter-duration="1" class="purecounter fw-bold mb-1">0</h2>
                    <p class="text-muted fw-semibold mb-0">Internships Provided</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card shadow-sm" style="border-bottom-color: #15be56;">
                    <i class="bi bi-clock-history fs-1 mb-3 d-block" style="color: #15be56;"></i>
                    <h2 data-purecounter-start="0" data-purecounter-end="1463" data-purecounter-duration="1" class="purecounter fw-bold mb-1">0</h2>
                    <p class="text-muted fw-semibold mb-0">Hours of Coding</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stat-card shadow-sm" style="border-bottom-color: #bb0852;">
                    <i class="bi bi-layers fs-1 mb-3 d-block" style="color: #bb0852;"></i>
                    <h2 data-purecounter-start="0" data-purecounter-end="6" data-purecounter-duration="1" class="purecounter fw-bold mb-1">0</h2>
                    <p class="text-muted fw-semibold mb-0">Specialized Domains</p>
                </div>
            </div>

        </div>
    </div>
</section>

